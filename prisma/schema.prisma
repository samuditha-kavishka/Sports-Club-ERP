generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Member {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  phone     String?
  joinDate  DateTime  @default(now())
  bookings  Booking[]
  invoices  Invoice[]
}

model Facility {
  id         Int       @id @default(autoincrement())
  name       String
  hourlyRate Float
  bookings   Booking[]
}

model Booking {
  id            Int      @id @default(autoincrement())
  memberId      Int
  facilityId    Int
  bookingDate   DateTime
  durationHours Float
  member        Member   @relation(fields: [memberId], references: [id])
  facility      Facility @relation(fields: [facilityId], references: [id])
  invoices      Invoice[]
}

model Invoice {
  id          Int      @id @default(autoincrement())
  memberId    Int
  bookingId   Int
  totalAmount Float
  status      String   @default("Pending") // "Pending", "Paid"
  member      Member   @relation(fields: [memberId], references: [id])
  booking     Booking  @relation(fields: [bookingId], references: [id])
}

model Inventory {
  id              Int      @id @default(autoincrement())
  itemName        String
  quantityInStock Int
  unitPrice       Float
}
